import PyPDF2
import io

def extract_text_from_pdf(file_bytes: bytes) -> str:
	pdf_reader = PyPDF2.PdfReader(io.BytesIO(file_bytes))

	text = "" 
	for page in pdf_reader.pages:
		text += page.extract_text() or ""
	
	return text


